<?xml version="1.0" encoding="utf-8"?>
<Mod id="Proper_Football_Total_Conversion" version="1">
  <Properties>
    <Name>Proper Football</Name>
    <Description>A total conversion replacing empires with the British Football Pyramid.</Description>
    <Created>2026</Created>
    <Teaser>The ultimate shithouse football simulator.</Teaser>
    <Authors>Legend</Authors>
  </Properties>
  
  <FrontEndActions>

      <File>English.properties</File>
    </UpdateText>
  </FrontEndActions>

  <InGameActions>
    <UpdateDatabase id="ProperFootball_Data">
      <File>ModOptions.json</File>
      <File>Techs.json</File>
      <File>Nations.json</File>
      <File>Buildings.json</File>
      <File>Units.json</File>
    </UpdateDatabase>
    <UpdateText id="ProperFootball_Text">
      <File>English.properties</File>
    </UpdateText>
  </InGameActions>

  <Files>
    <File>ModOptions.json</File>
    <File>Techs.json</File>
    <File>Nations.json</File>
    <File>Buildings.json</File>
    <File>Units.json</File>
    <File>English.properties</File>
  </Files>
</Mod>
